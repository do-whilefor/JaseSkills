{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Route candidate",
  "type": "object",
  "required": [
    "schema_version",
    "parser_mode",
    "routes"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "const": "route_candidates_v1"
    },
    "parser_mode": {
      "enum": [
        "regex_candidate_not_ast",
        "framework_parser",
        "mixed"
      ]
    },
    "routes": {
      "type": "array"
    },
    "warnings": {
      "type": "array"
    }
  }
}
