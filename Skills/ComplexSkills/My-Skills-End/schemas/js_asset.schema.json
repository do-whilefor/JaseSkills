{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JS asset extraction result",
  "type": "object",
  "required": [
    "schema_version",
    "parser_mode",
    "root",
    "assets",
    "endpoints"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "const": "js_asset_v1"
    },
    "parser_mode": {
      "enum": [
        "regex_candidate_not_ast",
        "babel_ast",
        "typescript_ast",
        "mixed"
      ]
    },
    "root": {
      "type": "string"
    },
    "assets": {
      "type": "array"
    },
    "endpoints": {
      "type": "array"
    },
    "source_maps": {
      "type": "array"
    },
    "graphql": {
      "type": "array"
    },
    "storage": {
      "type": "array"
    },
    "post_message": {
      "type": "array"
    },
    "secret_like": {
      "type": "array"
    },
    "warnings": {
      "type": "array"
    }
  }
}
