{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Browser Interaction Coverage Matrix",
  "type": "object",
  "required": ["schema_version", "non_destructive", "runtime_status", "required_actions", "coverage_rows", "evidence_gaps", "dynamic_claim_allowed"],
  "properties": {
    "schema_version": {"const": "browser_interaction_coverage_v1"},
    "non_destructive": {"const": true},
    "runtime_status": {"enum": ["browser_evidence_present", "runtime_missing", "partial_evidence", "planned_only"]},
    "required_actions": {"type": "array"},
    "coverage_rows": {"type": "array"},
    "evidence_gaps": {"type": "array"},
    "dynamic_claim_allowed": {"type": "boolean"},
    "role_tenant_matrix_present": {"type": "boolean"},
    "coverage_percent": {"type": "number", "minimum": 0, "maximum": 100}
  },
  "additionalProperties": true
}
