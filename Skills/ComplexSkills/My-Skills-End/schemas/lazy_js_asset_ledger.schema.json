{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lazy JS Asset Ledger",
  "type": "object",
  "required": ["schema_version", "non_destructive", "root", "files_scanned", "static_js_assets", "dynamic_imports", "source_maps", "service_workers", "api_clients", "browser_trigger_required", "evidence_gaps"],
  "properties": {
    "schema_version": {"const": "lazy_js_asset_ledger_v1"},
    "non_destructive": {"const": true},
    "root": {"type": "string"},
    "files_scanned": {"type": "integer", "minimum": 0},
    "static_js_assets": {"type": "array"},
    "html_js_references": {"type": "array"},
    "build_manifests": {"type": "array"},
    "source_maps": {"type": "array"},
    "service_workers": {"type": "array"},
    "dynamic_imports": {"type": "array"},
    "framework_lazy_routes": {"type": "array"},
    "frontend_routes": {"type": "array"},
    "api_clients": {"type": "array"},
    "graphql": {"type": "array"},
    "websocket_sse": {"type": "array"},
    "feature_flags": {"type": "array"},
    "hidden_route_signals": {"type": "array"},
    "browser_trigger_required": {"type": "array"},
    "evidence_gaps": {"type": "array"},
    "completion_policy": {"type": "string"}
  },
  "additionalProperties": true
}
