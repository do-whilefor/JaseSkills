{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evaluation Claim Traceability Schema v1",
  "type": "object",
  "required": [
    "schema",
    "claims"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "evaluation_claim_traceability_v1"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "concrete_file_path",
          "concrete_problem_position",
          "original_evidence",
          "why_this_is_problem",
          "consequence",
          "repair_file",
          "rule_change",
          "template_change",
          "script_change",
          "test_change",
          "test_input_sample",
          "expected_output",
          "failure_judgement_standard",
          "quality_threshold",
          "priority"
        ],
        "properties": {
          "priority": {
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          }
        }
      }
    }
  }
}