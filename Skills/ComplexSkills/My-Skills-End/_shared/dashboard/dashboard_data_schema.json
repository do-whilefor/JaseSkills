{
  "schema_version": "1.1",
  "required_columns": [
    "Manifest",
    "Template",
    "Route",
    "Candidate",
    "Evidence",
    "Quality Gate",
    "Report",
    "Status"
  ],
  "data_sources": [
    "canonical replay evidence manifests",
    "_shared/template_index.json",
    "_shared/quality/quality_gate_v4_1.py",
    "_shared/tools/tool_health_score.json"
  ],
  "policy": "Dashboard must display blocked when manifest or QG evidence is missing; it must not invent confirmed results.",
  "properties": {
    "data_source": {
      "type": "string",
      "enum": [
        "fixture_replay",
        "live_run",
        "mixed"
      ]
    },
    "fixture_mode": {
      "type": "boolean"
    }
  },
  "x_policy": "Dashboard must label fixture data vs live run data; fixture mode cannot be represented as confirmed real findings."
}
