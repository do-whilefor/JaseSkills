{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Executable Vulnerability Template Overlay v1",
  "type": "object",
  "required": [
    "schema_version",
    "template_path",
    "template_id",
    "triggers",
    "sources",
    "sinks",
    "guards",
    "positive_tests",
    "negative_tests",
    "blocked_tests",
    "needs_review_tests",
    "evidence_required",
    "promotion_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "executable_template_overlay_v1"
    },
    "template_path": {
      "type": "string"
    },
    "template_id": {
      "type": "string"
    },
    "triggers": {
      "type": "array"
    },
    "sources": {
      "type": "array"
    },
    "sinks": {
      "type": "array"
    },
    "guards": {
      "type": "array"
    },
    "positive_tests": {
      "type": "array"
    },
    "negative_tests": {
      "type": "array"
    },
    "blocked_tests": {
      "type": "array"
    },
    "needs_review_tests": {
      "type": "array"
    },
    "evidence_required": {
      "type": "array"
    },
    "promotion_policy": {
      "type": "string"
    }
  }
}