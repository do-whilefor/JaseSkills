{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "js-semantic-graph.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "semantic_status",
    "nodes",
    "edges",
    "coverage"
  ],
  "properties": {
    "schema_version": {
      "const": "js-semantic-graph/v1"
    },
    "semantic_status": {
      "type": "string"
    },
    "nodes": {
      "type": "array"
    },
    "edges": {
      "type": "array"
    },
    "coverage": {
      "type": "object"
    },
    "backend_results": {
      "type": "array"
    }
  }
}