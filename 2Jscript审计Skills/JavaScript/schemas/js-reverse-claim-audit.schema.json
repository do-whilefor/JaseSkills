{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "js-reverse-claim-audit.schema.json",
  "type": "object",
  "required": ["schema_version", "ok", "summary", "classifications", "withdrawals", "blocking_fixes"],
  "properties": {
    "schema_version": {"const": "js-reverse-claim-audit/v1"},
    "ok": {"type": "boolean"},
    "summary": {
      "type": "object",
      "required": ["A", "B", "C"],
      "properties": {
        "A": {"type": "integer"},
        "B": {"type": "integer"},
        "C": {"type": "integer"}
      }
    },
    "classifications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "class", "status", "evidence", "verdict"],
        "properties": {
          "claim": {"type": "string"},
          "class": {"enum": ["A", "B", "C"]},
          "status": {"enum": ["ready", "partial", "needs_review", "withdrawn", "blocked"]},
          "evidence": {"type": "array"},
          "verdict": {"type": "string"},
          "required_command": {"type": "string"}
        }
      }
    },
    "withdrawals": {"type": "array"},
    "blocking_fixes": {"type": "array"}
  },
  "additionalProperties": true
}
