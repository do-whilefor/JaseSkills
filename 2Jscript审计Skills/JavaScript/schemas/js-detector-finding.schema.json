{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "js-detector-finding.schema.json",
  "type": "object",
  "required": [
    "finding_id",
    "rule_id",
    "title",
    "status",
    "evidence",
    "promotion_blockers"
  ],
  "properties": {
    "finding_id": {
      "type": "string"
    },
    "rule_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "enum": [
        "candidate",
        "needs_review",
        "confirmed",
        "false_positive"
      ]
    },
    "evidence": {
      "type": "array"
    },
    "promotion_blockers": {
      "type": "array"
    },
    "redaction_status": {
      "type": "string"
    }
  }
}