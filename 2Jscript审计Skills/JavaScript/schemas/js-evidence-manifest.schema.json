{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "js-evidence-manifest.schema.json",
  "title": "js-evidence-manifest.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "evidence_root",
    "runtime_requirements",
    "artifacts",
    "request_response_index"
  ],
  "properties": {
    "schema_version": {
      "const": "js-evidence-manifest/v1"
    },
    "status": {
      "enum": [
        "missing",
        "partial",
        "ready"
      ]
    },
    "evidence_root": {
      "type": "string"
    },
    "runtime_requirements": {
      "type": "object",
      "required": [
        "har",
        "trace",
        "screenshots",
        "request_response",
        "role_tenant_mapping"
      ],
      "properties": {
        "har": {
          "type": "boolean"
        },
        "trace": {
          "type": "boolean"
        },
        "screenshots": {
          "type": "boolean"
        },
        "request_response": {
          "type": "boolean"
        },
        "role_tenant_mapping": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "size",
          "kind"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "absolute_path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          },
          "kind": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "request_response_index": {
      "type": "array"
    },
    "downgrade": {
      "type": "string"
    }
  },
  "additionalProperties": true
}