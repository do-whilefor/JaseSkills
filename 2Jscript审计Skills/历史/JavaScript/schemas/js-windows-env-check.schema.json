{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JS Windows Environment Check",
  "type": "object",
  "required": ["schema_version", "ok", "host_platform", "windows_runtime_claim", "python_executable", "wrappers", "hardcoded_python3", "posix_only_findings"],
  "properties": {
    "schema_version": {"const": "js-windows-env-check/v1"},
    "ok": {"type": "boolean"},
    "host_platform": {"type": "string"},
    "simulate_windows": {"type": "boolean"},
    "windows_runtime_claim": {"enum": ["not-run-on-windows", "ran-on-windows-host"]},
    "python_executable": {"type": "string"},
    "package_scripts_checked": {"type": "array", "items": {"type": "string"}},
    "binaries": {"type": "array"},
    "wrappers": {"type": "array", "items": {"type": "object", "required": ["path", "exists"]}},
    "node_runner_help": {"type": "object"},
    "python_version": {"type": "object"},
    "hardcoded_python3": {"type": "array"},
    "posix_only_findings": {"type": "array"},
    "quality_rules": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
