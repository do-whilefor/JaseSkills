{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "js-authorized-target-import.schema.json",
  "type": "object",
  "required": ["schema_version", "status", "evidence_root", "authorized_target_import", "requirements", "blocking_reasons"],
  "properties": {
    "schema_version": {"const": "js-authorized-target-import/v1"},
    "status": {"enum": ["ready", "blocked"]},
    "evidence_root": {"type": "string"},
    "authorized_target_import": {"type": "boolean"},
    "requirements": {"type": "object"},
    "blocking_reasons": {"type": "array", "items": {"type":"string"}}
  },
  "additionalProperties": true
}
