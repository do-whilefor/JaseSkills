{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecKB Record Schema",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "category",
    "severity",
    "cwe",
    "owasp",
    "affected_products",
    "affected_versions",
    "fixed_versions",
    "published_date",
    "updated_date",
    "source_urls",
    "source_type",
    "source_confidence",
    "summary",
    "root_cause",
    "attack_preconditions",
    "impact",
    "dynamic_validation_safe_method",
    "local_lab_only",
    "false_positive_conditions",
    "cannot_report_reasons",
    "evidence_requirements",
    "patch_or_mitigation",
    "related_records",
    "tags",
    "last_checked",
    "review_status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "type": {
      "enum": [
        "cve",
        "advisory",
        "src_rule",
        "tool_release",
        "vuln_template",
        "code_audit_pattern",
        "report_template"
      ]
    },
    "category": {
      "type": "string"
    },
    "severity": {
      "type": "string"
    },
    "cwe": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "owasp": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affected_products": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affected_versions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fixed_versions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "published_date": {
      "type": "string"
    },
    "updated_date": {
      "type": "string"
    },
    "source_urls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_type": {
      "enum": [
        "official",
        "vendor",
        "platform",
        "research",
        "community",
        "unknown"
      ]
    },
    "source_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "summary": {
      "type": "string"
    },
    "root_cause": {
      "type": "string"
    },
    "attack_preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "impact": {
      "type": "string"
    },
    "dynamic_validation_safe_method": {
      "type": "string"
    },
    "local_lab_only": {
      "type": "boolean"
    },
    "false_positive_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cannot_report_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "patch_or_mitigation": {
      "type": "string"
    },
    "related_records": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_checked": {
      "type": "string"
    },
    "review_status": {
      "enum": [
        "promoted",
        "needs_review",
        "conflict",
        "stale",
        "rejected"
      ]
    },
    "freshness_scope": {
      "enum": [
        "last_30_days",
        "historical_high_value",
        "unknown"
      ]
    },
    "extension_label": {
      "type": "string",
      "enum": [
        "原文档",
        "基于文档延伸",
        "混合"
      ]
    },
    "cannot_deliver_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "index_entries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_conflict_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_confirmation_required": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}