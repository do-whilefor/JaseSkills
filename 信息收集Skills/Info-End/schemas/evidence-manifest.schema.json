{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/claude-skills/info-exposure/evidence-manifest.schema.json",
  "title": "Information Exposure Evidence Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "generated_at",
    "items"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "project": {
      "type": "object",
      "properties": {
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "root": {
          "type": [
            "string",
            "null"
          ]
        },
        "base_urls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "generated_at": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "kind"
        ],
        "properties": {
          "evidence_id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "asset_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "path": {
            "type": [
              "string",
              "null"
            ]
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ]
          },
          "size_bytes": {
            "type": [
              "integer",
              "null"
            ]
          },
          "summary": {
            "type": [
              "string",
              "null"
            ]
          },
          "qg": {
            "type": "object"
          },
          "redaction_status": {
            "type": "string"
          },
          "source": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
