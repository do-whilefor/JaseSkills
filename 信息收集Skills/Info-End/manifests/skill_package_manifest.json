{
  "schema_version": "1.0",
  "package_name": "info-exposure-audit-skills",
  "authorization_boundary": "Only local, owned, explicitly authorized repositories, labs, containers, services, accounts, and evidence files. No third-party target exploitation.",
  "runtime_status_policy": {
    "documentation_is_not_runtime_ready": true,
    "candidate_is_not_finding": true,
    "dynamic_validation_must_be_non_destructive": true,
    "full_secret_values_must_not_be_output": true
  },
  "required_indexes": [
    "manifests/skill_package_manifest.json",
    "manifests/template_index.json",
    "manifests/knowledge_index.json",
    "detectors/severe_vulnerability_matrix.yaml",
    "detectors/js_audit_coverage.yaml",
    "detectors/info_collection_coverage.yaml",
    "schemas/info-surface.schema.json",
    "schemas/runtime-evidence.schema.json",
    "schemas/finding-evidence-chain.schema.json"
  ],
  "skills": [
    {
      "id": "00",
      "path": "00-master-info-exposure-orchestrator/SKILL.md",
      "role": "orchestrator"
    },
    {
      "id": "01",
      "path": "01-scope-runtime-intake/SKILL.md",
      "role": "scope and runtime intake"
    },
    {
      "id": "02",
      "path": "02-runtime-entry-enumeration/SKILL.md",
      "role": "runtime entry enumeration"
    },
    {
      "id": "03",
      "path": "03-static-route-artifact-mining/SKILL.md",
      "role": "static route, artifact, JS asset, and parser-backed candidate mining"
    },
    {
      "id": "04",
      "path": "04-dynamic-exposure-validation/SKILL.md",
      "role": "non-destructive dynamic validation"
    },
    {
      "id": "05",
      "path": "05-role-diff-browser-storage/SKILL.md",
      "role": "role matrix and browser storage evidence"
    },
    {
      "id": "06",
      "path": "06-artifact-cache-container-edge-cases/SKILL.md",
      "role": "cache/container/edge-case coverage"
    },
    {
      "id": "07",
      "path": "07-evidence-reporting-quality-gate/SKILL.md",
      "role": "evidence manifest, QG scoring, reporting"
    },
    {
      "id": "08",
      "path": "08-skill-adversarial-audit-regression/SKILL.md",
      "role": "adversarial review and regression"
    }
  ],
  "core_scripts": [
    "scripts/parser-backend-check.py",
    "scripts/runtime-readiness-check.py",
    "scripts/code-surface-inventory.py",
    "scripts/js-asset-audit.py",
    "scripts/evidence-schema-validate.py",
    "scripts/run-package-selftest.sh",
    "dashboard/dashboard_generator.py",
    "scripts/config-dependency-inventory.py",
    "scripts/js-manifest-expander.py",
    "scripts/info-surface-normalizer.py",
    "scripts/js-ast-endpoint-extractor.mjs",
    "scripts/codegraph-builder.py",
    "scripts/source-sink-dataflow.py",
    "detectors/c01_c05_access_control.py",
    "scripts/qg-jsonl-score.py",
    "scripts/playwright-har-role-matrix.mjs",
    "scripts/ws-readonly-capture.mjs",
    "scripts/clean-release-artifacts.sh"
  ],
  "preservation_guarantee": {
    "templates_preserved": true,
    "knowledge_preserved": true,
    "cleanup_policy": "release notes, update reports, cache files, generated hash ledgers, and stale selftest outputs are excluded from the clean package"
  }
}
