{
  "version": ".hard-gate-v1",
  "default_decision": "blocked_until_proven",
  "min_score_for_quality_gate_passed": 85,
  "required_fields_for_confirmed": [
    "candidate_id",
    "vulnerability_type",
    "state",
    "source_file",
    "source_line",
    "route",
    "method",
    "parameter",
    "auth_context",
    "tenant_context",
    "code_evidence",
    "dynamic_evidence",
    "negative_control",
    "reproduction_count",
    "impact",
    "risk",
    "request_summary",
    "response_summary",
    "quality_gate_score",
    "state_transition_history"
  ],
  "hard_fail_conditions": [
    "unsafe_scope",
    "destructive_or_dos",
    "missing_code_evidence",
    "missing_dynamic_evidence",
    "missing_negative_control",
    "insufficient_reproduction",
    "tool_alert_only",
    "error_only_no_impact",
    "invalid_state_jump",
    "score_too_low",
    "chain_not_decomposed"
  ],
  "state_progression": [
    "discovered",
    "mapped",
    "triaged",
    "validation_planned",
    "reproduced",
    "negative_control_passed",
    "quality_gate_passed",
    "confirmed"
  ]
}