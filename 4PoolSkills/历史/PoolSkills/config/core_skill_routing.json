{
  "routing_version": ".reaudit.v1",
  "default_entry": "01-authorized-maximum-orchestrator",
  "hard_denies": [
    "third_party_unauthorized_target",
    "mitm",
    "dos_or_stress",
    "credential_spraying",
    "phishing_social_engineering",
    "persistence_backdoor",
    "destructive_data_change"
  ],
  "handoffs": [
    {
      "from": "01",
      "to": "02",
      "produces": [
        "project_inventory.json"
      ]
    },
    {
      "from": "02",
      "to": "03",
      "produces": [
        "code_graph.json"
      ]
    },
    {
      "from": "02",
      "to": "04",
      "produces": [
        "attack_surface.json"
      ]
    },
    {
      "from": "04",
      "to": "05",
      "produces": [
        "js_assets.json"
      ]
    },
    {
      "from": "03/04/05",
      "to": "07",
      "produces": [
        "candidate_manifest.json"
      ]
    },
    {
      "from": "07",
      "to": "06",
      "produces": [
        "dynamic_validation_plan.json",
        "evidence_manifest.json"
      ]
    },
    {
      "from": "06",
      "to": "08",
      "produces": [
        "quality_results.json"
      ]
    },
    {
      "from": "08",
      "to": "09",
      "produces": [
        "reports/*.md",
        "report_index.json"
      ]
    },
    {
      "from": "09",
      "to": "10",
      "produces": [
        "dashboard/index.html"
      ]
    }
  ]
}