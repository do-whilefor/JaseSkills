{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "local://authorized-security-audit/security_graph.schema.json",
  "title": "Security Graph Schema Audit",
  "type": "object",
  "required": [
    "schema_version",
    "nodes",
    "edges"
  ],
  "properties": {
    "schema_version": {
      "const": "audit-contract"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "node_type": {
      "enum": [
        "file",
        "module",
        "class",
        "function",
        "route",
        "parameter",
        "auth_middleware",
        "authorization_check",
        "data_model",
        "database_query",
        "file_operation",
        "network_request",
        "command_execution",
        "template_render",
        "deserialization",
        "upload_download",
        "source",
        "sink",
        "actor",
        "asset",
        "trust_boundary",
        "guard",
        "bypass_candidate",
        "evidence",
        "report_section"
      ]
    },
    "node": {
      "type": "object",
      "required": [
        "id",
        "type",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/node_type"
        },
        "label": {
          "type": "string"
        },
        "file": {
          "type": [
            "string",
            "null"
          ]
        },
        "line": {
          "type": [
            "integer",
            "null"
          ]
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "edge_type": {
      "enum": [
        "calls",
        "imports",
        "handles",
        "uses_guard",
        "checks",
        "reads",
        "writes",
        "flows_to",
        "crosses_boundary",
        "may_bypass",
        "proves",
        "reported_in",
        "owns",
        "belongs_to",
        "derived_from",
        "validates",
        "rejects"
      ]
    },
    "edge": {
      "type": "object",
      "required": [
        "from",
        "to",
        "type"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/edge_type"
        },
        "metadata": {
          "type": "object"
        }
      }
    }
  }
}
