{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Finding candidates",
  "type": "object",
  "required": [
    "schema_version",
    "scope",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "finding-candidates-v1"
    },
    "scope": {
      "type": "object"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "detector_id",
          "title",
          "severity_candidate",
          "confidence",
          "affected_files",
          "affected_routes",
          "source",
          "sink",
          "dataflow_path",
          "auth_context",
          "tenant_context",
          "required_role",
          "evidence_refs",
          "replay_plan_id",
          "negative_test_id",
          "blocked_test_id",
          "review_status"
        ],
        "properties": {
          "finding_id": {
            "type": "string"
          },
          "detector_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "severity_candidate": {
            "type": "string"
          },
          "confidence": {
            "type": "string"
          },
          "affected_files": {
            "type": "array"
          },
          "affected_routes": {
            "type": "array"
          },
          "source": {
            "type": "string"
          },
          "sink": {
            "type": "string"
          },
          "dataflow_path": {
            "type": "array"
          },
          "auth_context": {
            "type": "object"
          },
          "tenant_context": {
            "type": "object"
          },
          "required_role": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array"
          },
          "replay_plan_id": {
            "type": "string"
          },
          "negative_test_id": {
            "type": "string"
          },
          "blocked_test_id": {
            "type": "string"
          },
          "review_status": {
            "enum": [
              "candidate",
              "needs_review",
              "blocked",
              "confirmed",
              "false_positive",
              "not_reproducible"
            ]
          }
        }
      }
    }
  }
}
