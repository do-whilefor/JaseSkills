{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Security report index",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "findings"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "security-report-v1"
    },
    "status": {
      "enum": [
        "pass"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "title",
          "status",
          "severity_candidate",
          "confidence",
          "sanitized_evidence_paths",
          "dynamic_evidence_refs",
          "quality_checks",
          "limitations"
        ],
        "additionalProperties": false,
        "properties": {
          "finding_id": {
            "type": "string"
          },
          "title": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "enum": [
              "confirmed",
              "candidate",
              "needs_review",
              "blocked",
              "false_positive",
              "not_reproducible"
            ]
          },
          "severity_candidate": {
            "type": [
              "string",
              "null"
            ]
          },
          "confidence": {
            "type": [
              "string",
              "null"
            ]
          },
          "sanitized_evidence_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "dynamic_evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "quality_checks": {
            "type": "object"
          },
          "limitations": {
            "type": "array"
          }
        }
      }
    }
  }
}
