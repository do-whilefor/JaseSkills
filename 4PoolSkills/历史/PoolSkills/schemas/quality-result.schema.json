{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "overall_status",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "quality-result-v2"
    },
    "overall_status": {
      "enum": [
        "pass",
        "fail"
      ]
    },
    "hard_failures": {
      "type": "array"
    },
    "findings": {
      "type": "array"
    }
  }
}
