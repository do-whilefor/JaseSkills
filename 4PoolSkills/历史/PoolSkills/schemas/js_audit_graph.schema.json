{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JS audit graph v1",
  "type": "object",
  "required": [
    "schema_version",
    "nodes",
    "edges",
    "quality"
  ],
  "properties": {
    "schema_version": {
      "const": "js-audit-graph-v1"
    },
    "nodes": {
      "type": "array"
    },
    "edges": {
      "type": "array"
    },
    "quality": {
      "type": "object"
    }
  }
}
