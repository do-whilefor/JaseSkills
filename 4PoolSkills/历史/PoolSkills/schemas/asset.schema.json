{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Asset inventory v1",
  "type": "object",
  "required": [
    "schema_version",
    "project_root",
    "assets"
  ],
  "properties": {
    "schema_version": {
      "const": "asset-inventory-v1"
    },
    "project_root": {
      "type": "string"
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "path"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
