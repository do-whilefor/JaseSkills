{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Replay plan v1",
  "type": "object",
  "required": ["schema_version", "plans", "policy"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"const": "replay-plan-v1"},
    "policy": {"type": "string"},
    "plans": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["replay_plan_id", "finding_id", "mode", "steps", "non_destructive", "required_evidence"],
        "properties": {
          "replay_plan_id": {"type": "string"},
          "finding_id": {"type": "string"},
          "mode": {"type": "string"},
          "non_destructive": {"const": true},
          "target_path": {"type": "string"},
          "payload_policy": {"type": "string"},
          "steps": {
            "type": "array",
            "minItems": 4,
            "items": {
              "type": "object",
              "required": ["id", "action"],
              "properties": {
                "id": {"type": "string"},
                "action": {"enum": ["review_source_context", "goto", "click", "fill", "press", "wait_for_selector", "trigger_lazy_load", "negative_control", "blocked_control", "websocket_send", "websocket_subscribe", "graphql_request"]},
                "description": {"type": "string"},
                "url": {"type": "string"},
                "path": {"type": "string"},
                "method": {"type": "string"},
                "expected_status": {"type": "integer"},
                "forbidden_status": {"type": "integer"},
                "payload": {"type": "string"},
                "evidence_ref": {"type": ["string", "null"]},
                "selector": {"type": "string"},
                "value": {"type": "string"}
              }
            }
          },
          "required_evidence": {"type": "array", "contains": {"const": "request"}}
        }
      }
    }
  }
}
