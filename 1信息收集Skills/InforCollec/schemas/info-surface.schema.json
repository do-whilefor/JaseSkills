{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/claude-skills/info-exposure/info-surface.schema.json",
  "title": "Normalized Information Collection Surface",
  "type": "object",
  "required": [
    "schema_version",
    "asset_id",
    "source_file",
    "source_line",
    "source_type",
    "surface_type",
    "evidence_status",
    "review_status",
    "confidence"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "info-surface"},
    "asset_id": {"type": "string"},
    "source_file": {"type": ["string", "null"]},
    "source_line": {"type": ["integer", "null"], "minimum": 1},
    "source_type": {"type": "string"},
    "surface_type": {"type": "string"},
    "endpoint": {"type": ["string", "null"]},
    "method": {"type": ["string", "null"]},
    "parameter": {"type": ["string", "null"]},
    "auth_context": {"type": "string"},
    "role_context": {"type": "string"},
    "tenant_context": {"type": "string"},
    "data_object": {"type": ["string", "null"]},
    "evidence": {"type": "array", "items": {"type": "object"}},
    "candidate_vulnerability": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "detector_route": {"type": ["string", "null"]},
    "report_template": {"type": ["string", "null"]},
    "review_status": {"type": "string", "enum": ["promoted_candidate", "needs_review", "blocked", "rejected", "static_candidate"]},
    "evidence_status": {"type": "string", "enum": ["static_candidate", "runtime_evidence", "merged_candidate", "blocked_missing_evidence"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "dynamic_status": {"type": "string"},
    "quality_gate": {"type": "object"},
    "notes": {"type": ["string", "null"]}
  }
}
