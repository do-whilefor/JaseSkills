{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime-evidence.schema.json",
  "title": "Runtime Evidence Contract",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "mode",
    "scope_id",
    "records"
  ],
  "properties": {
    "schema_version": {
      "const": "runtime-evidence.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "contract_only",
        "playwright_capture",
        "har_import",
        "manual_authorized_capture",
        "local_loopback_safe_probe"
      ]
    },
    "playwright_available": {
      "type": "boolean"
    },
    "scope_id": {
      "type": "string",
      "minLength": 1
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role_context",
          "tenant_context",
          "url",
          "method",
          "capture_status",
          "safety"
        ],
        "properties": {
          "role_context": {
            "type": "string"
          },
          "tenant_context": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "method": {
            "type": "string"
          },
          "capture_status": {
            "enum": [
              "planned_not_captured",
              "captured",
              "blocked",
              "failed",
              "pending_capture"
            ]
          },
          "request_sample": {},
          "response_sample": {},
          "screenshot": {},
          "har_entry": {},
          "safety": {
            "type": "string"
          },
          "source_evidence_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "source_file": {
            "type": "string"
          },
          "source_line_start": {
            "type": "integer",
            "minimum": 1
          },
          "finding_status": {
            "enum": [
              "confirmed",
              "candidate",
              "needs_review",
              "rejected",
              "not_reportable",
              "out_of_scope"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "reason": {
            "type": "string"
          },
          "limitation": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "generated_at": {
      "type": "string"
    },
    "status": {
      "enum": [
        "PASS",
        "FAIL",
        "PARTIAL"
      ]
    },
    "base_url": {
      "type": "string"
    }
  }
}