{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/claude-skills/info-exposure/evidence-manifest.schema.json",
  "title": "Information Collection Evidence Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "generated_at",
    "items"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^(1\\.0|evidence-manifest\\.v[0-9]+)$"
    },
    "project": {
      "type": "object",
      "required": [
        "name",
        "root",
        "base_urls"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "root": {
          "type": [
            "string",
            "null"
          ]
        },
        "base_urls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "generated_at": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "kind",
          "collector_name",
          "skill_name",
          "source_file",
          "source_line_start",
          "source_line_end",
          "source_type",
          "discovered_item_type",
          "discovered_item_value_redacted",
          "raw_value_hash",
          "confidence",
          "severity_hint",
          "auth_relevance",
          "tenant_relevance",
          "role_relevance",
          "endpoint_relevance",
          "data_sensitivity",
          "reproduction_hint",
          "collection_time",
          "scope_id",
          "false_positive_reason",
          "needs_human_review",
          "linked_report_section",
          "path",
          "redaction_status",
          "collector_provenance",
          "finding_status",
          "reason",
          "raw_evidence_hash",
          "redacted_evidence",
          "reproduction_command",
          "limitation"
        ],
        "additionalProperties": true,
        "properties": {
          "evidence_id": {
            "type": "string",
            "pattern": "^ev-[a-f0-9]{8,64}$"
          },
          "kind": {
            "type": "string"
          },
          "collector_name": {
            "type": "string",
            "minLength": 1
          },
          "skill_name": {
            "type": "string",
            "minLength": 1
          },
          "source_file": {
            "type": "string"
          },
          "source_line_start": {
            "type": "integer",
            "minimum": 1
          },
          "source_line_end": {
            "type": "integer",
            "minimum": 1
          },
          "source_type": {
            "type": "string"
          },
          "discovered_item_type": {
            "type": "string",
            "minLength": 1
          },
          "discovered_item_value_redacted": {},
          "raw_value_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "severity_hint": {
            "type": "string"
          },
          "auth_relevance": {
            "type": "string"
          },
          "tenant_relevance": {
            "type": "string"
          },
          "role_relevance": {
            "type": "string"
          },
          "endpoint_relevance": {
            "type": "string"
          },
          "data_sensitivity": {
            "type": "string"
          },
          "reproduction_hint": {
            "type": "string"
          },
          "collection_time": {
            "type": "string"
          },
          "scope_id": {
            "type": "string"
          },
          "false_positive_reason": {
            "type": "string"
          },
          "needs_human_review": {
            "type": "boolean"
          },
          "linked_report_section": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string"
          },
          "redaction_status": {
            "type": "string",
            "enum": [
              "redacted",
              "not_sensitive_or_no_secret_literal",
              "redacted_or_not_sensitive"
            ]
          },
          "collector_provenance": {
            "type": "object",
            "required": [
              "collector",
              "source",
              "network"
            ],
            "additionalProperties": true,
            "properties": {
              "collector": {
                "type": "string"
              },
              "source": {
                "type": "string"
              },
              "network": {
                "type": "string"
              }
            }
          },
          "finding_status": {
            "type": "string",
            "enum": [
              "confirmed",
              "candidate",
              "needs_review",
              "rejected",
              "not_reportable",
              "out_of_scope"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "raw_evidence_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "redacted_evidence": {},
          "reproduction_command": {
            "type": "string",
            "minLength": 1
          },
          "limitation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
