{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/info-end/endpoint.schema.json",
  "title": "Info-End Endpoint Evidence",
  "type": "object",
  "required": ["route", "method", "source_file", "line", "evidence_id", "status"],
  "additionalProperties": true,
  "properties": {
    "route": {"type": "string", "minLength": 1},
    "method": {"type": "string", "minLength": 1},
    "handler": {"type": ["string", "null"]},
    "middleware": {"type": ["string", "array", "null"]},
    "authn": {"type": ["string", "null"]},
    "authz": {"type": ["string", "null"]},
    "parameters": {"type": "array"},
    "source_file": {"type": "string"},
    "line": {"type": "integer", "minimum": 1},
    "evidence_id": {"type": "string"},
    "status": {"type": "string", "enum": ["confirmed", "candidate", "needs_review", "rejected", "not_reportable", "out_of_scope"]}
  }
}
