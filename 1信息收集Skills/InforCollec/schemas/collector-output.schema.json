{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/info-end/collector-output.schema.json",
  "title": "Info-End Collector Output",
  "type": "object",
  "required": ["schema_version", "collector_name", "skill_name", "input", "scope", "generated_at", "items"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+\\.v[0-9]+$"},
    "collector_name": {"type": "string", "minLength": 1},
    "skill_name": {"const": "Info-End"},
    "input": {"type": ["string", "null"]},
    "scope": {"type": ["string", "null"]},
    "network": {"type": "string"},
    "dry_run": {"type": "boolean"},
    "generated_at": {"type": "string"},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id", "collector_name", "source_file", "source_line_start", "source_line_end",
          "discovered_item_type", "discovered_item_value_redacted", "raw_value_hash", "confidence",
          "linked_report_section", "finding_status", "reason", "raw_evidence_hash", "redacted_evidence",
          "reproduction_command", "limitation", "scope_id"
        ],
        "additionalProperties": true,
        "properties": {
          "evidence_id": {"type":"string", "pattern":"^ev-[a-f0-9]{8,64}$"},
          "collector_name": {"type":"string", "minLength":1},
          "source_file": {"type":"string", "minLength":1},
          "source_line_start": {"type":"integer", "minimum":1},
          "source_line_end": {"type":"integer", "minimum":1},
          "discovered_item_type": {"type":"string", "minLength":1},
          "raw_value_hash": {"type":"string", "pattern":"^[a-f0-9]{64}$"},
          "raw_evidence_hash": {"type":"string", "pattern":"^[a-f0-9]{64}$"},
          "confidence": {"type":"number", "minimum":0, "maximum":1},
          "linked_report_section": {"type":"string", "minLength":1},
          "finding_status": {"enum":["confirmed","candidate","needs_review","rejected","not_reportable","out_of_scope"]},
          "reason": {"type":"string", "minLength":1},
          "reproduction_command": {"type":"string", "minLength":1},
          "limitation": {"type":"string", "minLength":1},
          "scope_id": {"type":"string", "minLength":1}
        }
      }
    },
    "coverage": {"type": "object"}
  }
}
