{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Frontend/backend parameter diff schema",
  "type": "object",
  "required": ["schema_version", "backend_parameter_count", "frontend_parameter_count", "backend_only_parameters", "frontend_only_parameters", "does_not_confirm", "claim_policy"],
  "properties": {
    "schema_version": {"const": "frontend_backend_parameter_diff_v1"},
    "backend_parameter_count": {"type": "integer", "minimum": 0},
    "frontend_parameter_count": {"type": "integer", "minimum": 0},
    "backend_only_count": {"type": "integer", "minimum": 0},
    "frontend_only_count": {"type": "integer", "minimum": 0},
    "backend_only_parameters": {"type": "array"},
    "frontend_only_parameters": {"type": "array"},
    "sensitive_backend_only": {"type": "array"},
    "does_not_confirm": {"const": true},
    "claim_policy": {"type": "string"}
  },
  "additionalProperties": true
}
