{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Extended severe detector rule schema v2",
  "type": "object",
  "required": [
    "schema_version",
    "detector_id",
    "vulnerability_type",
    "canonical_template_id",
    "source_rules",
    "sink_rules",
    "sanitizer_validator_rules",
    "authn_rules",
    "authz_rules",
    "tenant_rules",
    "evidence_requirements",
    "non_destructive_validation",
    "fixtures",
    "report_template_mapping",
    "quality_gate_weight",
    "claim_policy",
    "validation_contract",
    "sample_coverage"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "const": "extended_detector_rule_v2"
    },
    "detector_id": {
      "type": "string",
      "pattern": "^D(0[1-9]|[1-3][0-9]|40)$"
    },
    "vulnerability_type": {
      "type": "string",
      "minLength": 3
    },
    "canonical_template_id": {
      "type": "string",
      "pattern": "^C[0-9]{2}-"
    },
    "source_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "sink_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "sanitizer_validator_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "authn_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "authz_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "tenant_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "evidence_requirements": {
      "type": "object",
      "required": [
        "candidate",
        "needs_review",
        "confirmed"
      ],
      "properties": {
        "candidate": {
          "type": "array",
          "minItems": 1
        },
        "needs_review": {
          "type": "array",
          "minItems": 1
        },
        "confirmed": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "non_destructive_validation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "fixtures": {
      "type": "object",
      "required": [
        "positive",
        "negative",
        "blocked",
        "human_review"
      ],
      "additionalProperties": false,
      "properties": {
        "positive": {
          "type": "string",
          "pattern": "^_shared/tests/fixtures/extended_40/D[0-9]{2}-positive\\.json$"
        },
        "negative": {
          "type": "string",
          "pattern": "^_shared/tests/fixtures/extended_40/D[0-9]{2}-negative\\.json$"
        },
        "blocked": {
          "type": "string",
          "pattern": "^_shared/tests/fixtures/extended_40/D[0-9]{2}-blocked\\.json$"
        },
        "human_review": {
          "type": "string",
          "pattern": "^_shared/tests/fixtures/extended_40/D[0-9]{2}-human_review\\.json$"
        }
      }
    },
    "report_template_mapping": {
      "type": "string",
      "minLength": 5
    },
    "quality_gate_weight": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "claim_policy": {
      "type": "string",
      "pattern": "(?i)(not confirmed|confirmed requires|candidate)"
    },
    "validation_contract": {
      "type": "object",
      "required": [
        "emits_confirmed",
        "requires_dynamic_evidence_for_confirmed",
        "requires_evidence_id_for_every_claim",
        "requires_secret_redaction_before_report"
      ],
      "properties": {
        "emits_confirmed": {
          "const": false
        },
        "requires_dynamic_evidence_for_confirmed": {
          "const": true
        },
        "requires_evidence_id_for_every_claim": {
          "const": true
        },
        "requires_secret_redaction_before_report": {
          "const": true
        }
      }
    },
    "sample_coverage": {
      "type": "object",
      "required": [
        "positive",
        "negative",
        "blocked",
        "human_review"
      ]
    }
  }
}
