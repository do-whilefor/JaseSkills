{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Performance dedupe noise gate result",
  "type": "object",
  "required": [
    "schema_version",
    "passed",
    "candidate_count",
    "duplicate_count",
    "noise_filtered_count",
    "elapsed_seconds",
    "limits"
  ],
  "properties": {
    "schema_version": {
      "const": "performance_dedupe_noise_gate_v1"
    },
    "passed": {
      "type": "boolean"
    },
    "candidate_count": {
      "type": "integer"
    },
    "duplicate_count": {
      "type": "integer"
    },
    "noise_filtered_count": {
      "type": "integer"
    },
    "elapsed_seconds": {
      "type": "number"
    },
    "limits": {
      "type": "object"
    },
    "blockers": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
