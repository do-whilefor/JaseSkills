{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Controller service repository authz consistency proof",
  "type": "object",
  "required": [
    "schema_version",
    "proof_count",
    "proofs",
    "promotion_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "authz_path_consistency_proof_v1"
    },
    "proof_count": {
      "type": "integer"
    },
    "proofs": {
      "type": "array"
    },
    "promotion_policy": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
