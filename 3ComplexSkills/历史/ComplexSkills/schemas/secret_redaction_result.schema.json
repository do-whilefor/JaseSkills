{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Secret redaction gate result schema v2",
  "type": "object",
  "required": [
    "schema_version",
    "scanned_path_count",
    "finding_count",
    "passed",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "secret_redaction_gate_v2"
    },
    "scanned_path_count": {
      "type": "integer"
    },
    "finding_count": {
      "type": "integer"
    },
    "passed": {
      "type": "boolean"
    },
    "findings": {
      "type": "array"
    }
  }
}
