{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence_manifest_v5_overlay.schema.json",
  "title": "Evidence Manifest v5 Overlay for Real Browser + Lazy JS Proof",
  "type": "object",
  "required": [
    "manifest_id",
    "final_status",
    "scope",
    "code_evidence",
    "dynamic_evidence",
    "negative_controls",
    "browser_interaction_coverage",
    "lazy_js_asset_ledger",
    "role_tenant_matrix",
    "variant_expansion"
  ],
  "properties": {
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "final_status": {
      "enum": [
        "candidate",
        "needs_human_review",
        "blocked",
        "rejected",
        "confirmed"
      ]
    },
    "scope": {
      "type": "object"
    },
    "code_evidence": {
      "type": "array",
      "minItems": 1
    },
    "dynamic_evidence": {
      "type": "array"
    },
    "negative_controls": {
      "type": "array"
    },
    "browser_interaction_coverage": {
      "type": "object",
      "required": [
        "observed_actions",
        "dynamic_claim_allowed"
      ],
      "properties": {
        "observed_actions": {
          "type": "array"
        },
        "dynamic_claim_allowed": {
          "type": "boolean"
        }
      }
    },
    "lazy_js_asset_ledger": {
      "type": "object",
      "required": [
        "files_scanned"
      ],
      "properties": {
        "files_scanned": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "role_tenant_matrix": {
      "type": "object",
      "required": [
        "roles",
        "tenants",
        "test_cases"
      ],
      "properties": {
        "roles": {
          "type": "array"
        },
        "tenants": {
          "type": "array"
        },
        "test_cases": {
          "type": "array"
        }
      }
    },
    "variant_expansion": {
      "type": "object",
      "required": [
        "expansions"
      ],
      "properties": {
        "expansions": {
          "type": "array"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "final_status": {
            "const": "confirmed"
          }
        }
      },
      "then": {
        "properties": {
          "dynamic_evidence": {
            "minItems": 3
          },
          "negative_controls": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
