{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dynamic evidence artifact group schema v2",
  "type": "object",
  "required": [
    "case_id",
    "non_destructive",
    "artifacts"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "non_destructive": {
      "const": true
    },
    "artifacts": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "type",
          "path",
          "sha256",
          "redacted"
        ],
        "properties": {
          "type": {
            "enum": [
              "request",
              "response",
              "screenshot",
              "dom",
              "console",
              "har",
              "trace",
              "storage_state",
              "other"
            ]
          },
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "redacted": {
            "const": true
          }
        }
      }
    }
  }
}
