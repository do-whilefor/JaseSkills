{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Explicit manifest index",
  "type": "object",
  "required": [
    "schema_version",
    "source_policy",
    "manifests"
  ],
  "properties": {
    "schema_version": {
      "const": "manifest_index_v1"
    },
    "source_policy": {
      "const": "explicit_manifest_index_only"
    },
    "manifests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "fixture_allowed"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "fixture_allowed": {
            "type": "boolean"
          },
          "final_status": {
            "type": "string"
          },
          "evidence_id": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
