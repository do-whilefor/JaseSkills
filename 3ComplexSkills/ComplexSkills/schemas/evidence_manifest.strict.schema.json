{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Strict evidence manifest schema v2",
  "type": "object",
  "required": [
    "schema_version",
    "manifest_id",
    "candidate_id",
    "evidence_id",
    "template_id",
    "final_status",
    "authorization_scope",
    "state",
    "state_history",
    "route",
    "method",
    "parameter",
    "code_evidence",
    "dynamic_evidence",
    "negative_control",
    "request_response_summaries",
    "command_outputs",
    "quality",
    "redaction",
    "taint_review",
    "report_claims",
    "report_renderer",
    "tool_snapshot",
    "non_destructive_boundary"
  ],
  "properties": {
    "schema_version": {
      "enum": [
        "evidence_manifest_v1",
        "evidence_manifest_v4.1",
        "evidence_manifest_strict_v2"
      ]
    },
    "manifest_id": {
      "type": "string",
      "minLength": 3
    },
    "candidate_id": {
      "type": "string",
      "minLength": 3
    },
    "evidence_id": {
      "type": "string",
      "pattern": "^EVID-"
    },
    "template_id": {
      "type": "string",
      "pattern": "^C[0-9]{2}-"
    },
    "final_status": {
      "enum": [
        "candidate",
        "needs_review",
        "confirmed",
        "blocked",
        "rejected",
        "inconclusive",
        "needs_human_review"
      ]
    },
    "authorization_scope": {
      "enum": [
        "local_authorized_fixture_only",
        "local_authorized_project_only",
        "blocked_out_of_scope"
      ]
    },
    "state": {
      "type": "string"
    },
    "state_history": {
      "type": "array",
      "minItems": 1
    },
    "route": {
      "type": "string"
    },
    "method": {
      "type": "string"
    },
    "parameter": {
      "type": "string"
    },
    "code_evidence": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "dynamic_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "non_destructive",
          "artifacts"
        ],
        "properties": {
          "case_id": {
            "type": "string"
          },
          "non_destructive": {
            "const": true
          },
          "artifacts": {
            "type": "array",
            "minItems": 2
          }
        }
      }
    },
    "negative_control": {
      "type": "array"
    },
    "role_object_tenant_ledger": {
      "type": "object"
    },
    "request_response_summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "request_summary",
          "response_summary",
          "redacted"
        ],
        "properties": {
          "case_id": {
            "type": "string"
          },
          "request_summary": {
            "type": "string"
          },
          "response_summary": {
            "type": "string"
          },
          "redacted": {
            "const": true
          }
        }
      }
    },
    "command_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command_id",
          "command",
          "exit_code",
          "stdout_sha256",
          "stderr_sha256",
          "artifact_path",
          "redacted"
        ],
        "properties": {
          "command_id": {
            "type": "string"
          },
          "command": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "exit_code": {
            "type": "integer"
          },
          "stdout_sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "stderr_sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "artifact_path": {
            "type": "string"
          },
          "redacted": {
            "const": true
          }
        }
      }
    },
    "quality": {
      "type": "object"
    },
    "redaction": {
      "type": "object",
      "required": [
        "secrets_scanned",
        "second_pass_complete"
      ],
      "properties": {
        "secrets_scanned": {
          "const": true
        },
        "second_pass_complete": {
          "const": true
        }
      }
    },
    "taint_review": {
      "type": "object"
    },
    "report_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "evidence_id",
          "level",
          "text"
        ],
        "properties": {
          "claim_id": {
            "type": "string"
          },
          "evidence_id": {
            "type": "string",
            "pattern": "^EVID-"
          },
          "level": {
            "enum": [
              "candidate",
              "needs_review",
              "confirmed",
              "blocked",
              "rejected",
              "inconclusive"
            ]
          },
          "text": {
            "type": "string"
          }
        }
      }
    },
    "report_renderer": {
      "type": "object"
    },
    "tool_snapshot": {
      "type": "object"
    },
    "non_destructive_boundary": {
      "type": "object"
    }
  },
  "if": {
    "properties": {
      "final_status": {
        "const": "confirmed"
      }
    }
  },
  "then": {
    "required": [
      "role_object_tenant_ledger"
    ],
    "properties": {
      "code_evidence": {
        "minItems": 1
      },
      "dynamic_evidence": {
        "minItems": 3
      },
      "negative_control": {
        "minItems": 1
      },
      "request_response_summaries": {
        "minItems": 3
      },
      "command_outputs": {
        "minItems": 1
      },
      "report_claims": {
        "minItems": 1
      },
      "role_object_tenant_ledger": {
        "required": [
          "complete",
          "object_bindings",
          "negative_control_coverage"
        ],
        "properties": {
          "complete": {
            "const": true
          },
          "object_bindings": {
            "type": "array",
            "minItems": 1
          },
          "negative_control_coverage": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    }
  },
  "additionalProperties": true
}
