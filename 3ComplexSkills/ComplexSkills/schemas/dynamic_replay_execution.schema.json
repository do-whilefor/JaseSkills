  "title": "Dynamic replay execution ledger",
  "type": "object",
  "required": [
    "schema_version",
    "executor",
    "executed",
    "rows",
    "promotion_policy"
  ],
  "properties": {
    "schema_version": {
      "enum": [
        "playwright_multirole_replay_v1",
        "har_role_tenant_merge_v1",
        "graphql_resolver_replay_v1",
        "websocket_message_authz_replay_v1"
      ]
    },
    "executor": {
      "type": "string"
    },
    "executed": {
      "type": "boolean"
    },
    "rows": {
      "type": "array"
    },
    "promotion_policy": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
