{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Role tenant matrix schema v2",
  "type": "object",
  "required": [
    "schema_version",
    "non_destructive",
    "roles",
    "tenants",
    "test_case_count",
    "test_cases",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": "role_tenant_authz_matrix_v1"
    },
    "non_destructive": {
      "const": true
    },
    "roles": {
      "type": "array",
      "minItems": 2
    },
    "tenants": {
      "type": "array",
      "minItems": 2
    },
    "test_case_count": {
      "type": "integer",
      "minimum": 0
    },
    "test_cases": {
      "type": "array"
    },
    "status": {
      "type": "string"
    }
  }
}
