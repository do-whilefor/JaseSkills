{
  "package_name": "My-Skills-End",
  "install_mode": "single_root_skill_directory",
  "root_skill_entry": "SKILL.md",
  "core_skill_count": 10,
  "safety": {
    "local_authorized_only": true,
    "non_destructive_dynamic_validation_only": true,
    "no_direct_candidate_to_confirmed": true,
    "runtime_readiness_required_for_runtime_claims": true
  },
  "preserved_paths": [
    "_shared/knowledge/",
    "_shared/knowledge_index.json",
    "_shared/vulnerability_templates/",
    "skills/",
    "schemas/",
    "tools/",
    "tests/",
    "reports/templates/",
    "dashboard/",
    "_shared/requirements/"
  ],
  "canonical_vulnerability_templates": "_shared/vulnerability_templates/",
  "executable_template_overlays": "_shared/executable_template_overlays/",
  "claim_policy": "candidate_only_until_static_dynamic_role_tenant_negative_control_evidence_manifest_quality_gate_pass",
  "preservation_verified": {
    "knowledge_preserved": true,
    "templates_preserved": true,
    "extended_detectors_do_not_overwrite_canonical_templates": true
  }
}
