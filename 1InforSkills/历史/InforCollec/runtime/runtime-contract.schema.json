{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Authorized Runtime Contract",
  "type": "object",
  "required": ["scope_id", "base_urls", "roles", "tenants", "safety"],
  "properties": {
    "scope_id": {"type":"string"},
    "base_urls": {"type":"array", "items":{"type":"string"}},
    "roles": {"type":"array", "items":{"type":"object", "required":["name"], "properties":{"name":{"type":"string"}}}},
    "tenants": {"type":"array", "items":{"type":"object", "required":["name"], "properties":{"name":{"type":"string"}}}},
    "safety": {"type":"object"}
  }
}
