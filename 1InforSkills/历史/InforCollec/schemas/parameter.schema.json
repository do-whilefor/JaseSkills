{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/info-end/parameter.schema.json",
  "title": "Info-End Parameter Evidence",
  "type": "object",
  "required": ["name", "source", "source_file", "line", "evidence_id", "status"],
  "additionalProperties": true,
  "properties": {
    "name": {"type": "string", "minLength": 1},
    "source": {"type": "string"},
    "route": {"type": ["string", "null"]},
    "location": {"type": ["string", "null"], "enum": ["path", "query", "body", "header", "cookie", "graphql_variable", "websocket_payload", "multipart", "unknown", null]},
    "risk_tags": {"type": "array", "items": {"type": "string"}},
    "source_file": {"type": "string"},
    "line": {"type": "integer", "minimum": 1},
    "evidence_id": {"type": "string"},
    "status": {"type": "string", "enum": ["confirmed", "candidate", "needs_review", "rejected", "not_reportable", "out_of_scope"]}
  }
}
