{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/info-end/information-finding.schema.json",
  "title": "Info-End Information Finding",
  "type": "object",
  "required": ["id", "status", "title", "evidence_ids", "confidence", "reason", "limitation"],
  "additionalProperties": true,
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["confirmed", "candidate", "needs_review", "rejected", "not_reportable", "out_of_scope"]},
    "title": {"type": "string", "minLength": 1},
    "category": {"type": "string"},
    "evidence_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "reason": {"type": "string", "minLength": 1},
    "limitation": {"type": "string", "minLength": 1},
    "reproduction_command": {"type": "string"},
    "needs_online_verification": {"type": "boolean"}
  }
}
