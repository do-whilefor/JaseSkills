{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/info-end/analyzer-output.schema.json",
  "title": "Info-End Analyzer Output",
  "type": "object",
  "required": ["schema_version", "generated_at", "finding_count", "findings"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"const": "info-end-analyzer-output.v1"},
    "generated_at": {"type":"string"},
    "finding_count": {"type":"integer", "minimum":0},
    "findings": {
      "type":"array",
      "items": {
        "type":"object",
        "required":["id", "status", "title", "category", "evidence_ids", "confidence", "reason", "limitation", "generated_at"],
        "additionalProperties": true,
        "properties": {
          "id": {"type":"string", "minLength":1},
          "status": {"enum":["confirmed","candidate","needs_review","rejected","not_reportable","out_of_scope"]},
          "title": {"type":"string", "minLength":1},
          "category": {"type":"string", "minLength":1},
          "evidence_ids": {"type":"array", "items":{"type":"string"}},
          "confidence": {"type":"number", "minimum":0, "maximum":1},
          "reason": {"type":"string", "minLength":1},
          "limitation": {"type":"string", "minLength":1},
          "generated_at": {"type":"string"}
        }
      }
    }
  }
}
