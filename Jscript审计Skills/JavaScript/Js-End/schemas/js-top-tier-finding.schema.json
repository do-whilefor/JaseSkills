{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "js-top-tier-finding.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "js-top-tier-findings/v1"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "rule_id",
          "title",
          "status",
          "asset_path",
          "evidence_path",
          "backend",
          "dynamic_validation",
          "role_tenant_replay",
          "report_section",
          "reason"
        ],
        "properties": {
          "status": {
            "enum": [
              "ready",
              "partial",
              "doc-only",
              "candidate-only",
              "fake-ready",
              "missing",
              "conflict",
              "测试不足",
              "未动态验证"
            ]
          }
        }
      }
    }
  }
}