{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JS Runtime Evidence v2",
  "type": "object",
  "required": ["schema_version", "status", "requirements", "items"],
  "properties": {
    "schema_version": {"const": "js-runtime-evidence/v2"},
    "status": {"enum": ["ready", "partial", "missing"]},
    "requirements": {
      "type": "object",
      "required": ["har", "trace", "screenshots", "request_response", "role_tenant_mapping"],
      "properties": {
        "har": {"type": "boolean"},
        "trace": {"type": "boolean"},
        "screenshots": {"type": "boolean"},
        "request_response": {"type": "boolean"},
        "role_tenant_mapping": {"type": "boolean"}
      }
    },
    "items": {"type": "array"},
    "role_tenant_map": {"type": "array"}
  }
}
