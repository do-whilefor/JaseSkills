{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JS Backend Acceptance Evidence v1",
  "type": "object",
  "required": ["schema_version", "status", "probes"],
  "properties": {
    "schema_version": {"const": "js-backend-acceptance-evidence/v1"},
    "status": {"enum": ["ready", "partial", "missing"]},
    "probes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["baseline", "mutated", "verdict"],
        "properties": {
          "name": {"type": ["string", "null"]},
          "field": {"type": ["string", "null"]},
          "role": {"type": ["string", "null"]},
          "tenant": {"type": ["string", "null"]},
          "baseline": {"type": "object"},
          "mutated": {"type": "object"},
          "verdict": {"type": "string"}
        }
      }
    }
  }
}
