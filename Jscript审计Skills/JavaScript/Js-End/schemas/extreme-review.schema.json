{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Extreme JS Skills Review Result",
  "type": "object",
  "required": [
    "package",
    "scores",
    "findings",
    "status_legend"
  ],
  "properties": {
    "package": {
      "type": "object",
      "required": [
        "root",
        "file_count",
        "skill_count"
      ],
      "properties": {
        "root": {
          "type": "string"
        },
        "file_count": {
          "type": "integer"
        },
        "skill_count": {
          "type": "integer"
        }
      }
    },
    "status_legend": {
      "type": "array",
      "items": {
        "enum": [
          "ready",
          "partial",
          "doc-only",
          "fake-ready",
          "missing",
          "conflict",
          "未证实"
        ]
      }
    },
    "scores": {
      "type": "object",
      "properties": {
        "structure": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "info_collection": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "js_collection": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15
        },
        "semantic_audit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "severe_vuln": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "dynamic_evidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "tests_replay": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "knowledge_templates": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "total": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "priority",
          "path_or_object",
          "problem",
          "evidence"
        ],
        "properties": {
          "priority": {
            "enum": [
              "P0",
              "P1",
              "P2"
            ]
          },
          "path_or_object": {
            "type": "string"
          },
          "problem": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "fix": {
            "type": "string"
          }
        }
      }
    }
  }
}