{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JS Evidence Manifest",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "severity",
    "status",
    "scope",
    "code_evidence",
    "dynamic_requests",
    "dynamic_responses",
    "reproduce_count",
    "impact",
    "false_positive_checks",
    "fix"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "severity": {
      "type": "string"
    },
    "status": {
      "enum": [
        "candidate",
        "verified",
        "false_positive",
        "insufficient_evidence",
        "not_reportable",
        "not_deliverable"
      ]
    },
    "scope": {
      "type": "object",
      "required": [
        "authorized",
        "target",
        "environment",
        "non_destructive"
      ],
      "properties": {
        "authorized": {
          "type": "boolean"
        },
        "target": {
          "type": "string"
        },
        "service_url": {
          "type": "string"
        },
        "environment": {
          "type": "string"
        },
        "non_destructive": {
          "type": "boolean"
        }
      }
    },
    "code_evidence": {
      "type": "array"
    },
    "dynamic_requests": {
      "type": "array"
    },
    "dynamic_responses": {
      "type": "array"
    },
    "screenshots": {
      "type": "array"
    },
    "logs": {
      "type": "array"
    },
    "reproductions": {
      "type": "array"
    },
    "reproduce_count": {
      "type": "integer",
      "minimum": 0
    },
    "accounts_used": {
      "type": "array"
    },
    "impact": {
      "type": "string"
    },
    "false_positive_checks": {
      "type": "array"
    },
    "counter_examples": {
      "type": "array"
    },
    "not_reportable_reason": {
      "type": "string"
    },
    "not_deliverable_reason": {
      "type": "string"
    },
    "fix": {
      "type": "string"
    }
  }
}
